FROM node:22-bookworm-slim AS builder

WORKDIR /app

COPY package.json package-lock.json tsconfig*.json vite.config.ts postcss.config.js tailwind.config.js index.html ./
COPY src ./src
COPY public ./public

ARG VITE_STUDIO_API_BASE_URL=
ENV VITE_STUDIO_API_BASE_URL=${VITE_STUDIO_API_BASE_URL}

RUN npm ci
RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/self-hosted/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
